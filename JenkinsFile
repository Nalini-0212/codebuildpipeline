pipeline{
    agent any{
        tools{
            MAVEN = "maven3.9"
            JDK = "JDK17"
        }
        environment{
            DOCKER_IMAGE_NAME = "naliniselv/codepipeline"
            DOCKER_IMAGE_TAG = "latest"

        }
        stages{
            stage ("Build process"){
                steps{
                    sh "docker build -t myapp:v1.1 -f Dockerfile ."
                }
            }
            stage ("Unit Test"){
                steps{
                    sh 'mvn test'
                }
                
            }
            stage ("Docker login and push to Docker hub"){
                steps{
                    withCredentails([usernamepassword(
                        credentials_id:'dockercred',
                        dockeruser: 'DOCKER_USER',
                        dockerpass: 'DOCKER_PASS')]){
                            sh '''
                            docker tag $DOCKER_IMAGE_NAME:$DOCKER_IMAGE_TAG ${$DOCKER_USER}/$DOCKER_IMAGE_NAME:$DOCKER_IMAGE_TAG
                            echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin
                            docker push ${DOCKER_USER}/$DOCKER_IMAGE_NAME:$DOCKER_IMAGE_TAG
                            '''
                        }
                }
            }
        }
    }
}